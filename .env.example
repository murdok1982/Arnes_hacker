# ARNES FSOCIETY - Variables de Entorno

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=fsociety:latest

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Docker Configuration
DOCKER_SANDBOX_IMAGE=kalilinux/kali-rolling:latest
DOCKER_NETWORK_MODE=bridge
DOCKER_MEM_LIMIT=2g

# MCP Servers
MCP_NMAP_ENABLED=true
MCP_SQLMAP_ENABLED=true
MCP_NUCLEI_ENABLED=true
MCP_METASPLOIT_ENABLED=true

# Output Configuration
OUTPUT_DIR=./output
LOG_LEVEL=INFO

# Security
REQUIRE_AUTHORIZATION=true
DESTRUCTIVE_PAYLOADS_REQUIRE_DOUBLE_CONFIRM=true
